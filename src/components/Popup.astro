---
const {
  image = '',
  active = true,
} = Astro.props;
---

{active && image && (
  <div class="popup-overlay" id="popup-overlay" role="dialog" aria-modal="true" aria-label="Aviso promocional">
    <div class="popup-box">
      <button class="popup-close" id="popup-close" aria-label="Cerrar aviso">&times;</button>
      <img src={image} alt="Promoción Bolívar Plaza" loading="eager" class="popup-img" />
    </div>
  </div>
)}

<script>
  const overlay = document.getElementById('popup-overlay');
  const closeBtn = document.getElementById('popup-close');

  function closePopup() {
    if (overlay) {
      overlay.classList.add('closing');
      setTimeout(() => overlay.remove(), 260);
    }
  }

  closeBtn?.addEventListener('click', closePopup);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePopup();
  });
</script>

<style>
  .popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeIn 0.25s ease;
  }

  .popup-overlay.closing {
    animation: fadeOut 0.25s ease forwards;
  }

  .popup-box {
    position: relative;
    max-width: 500px;
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    animation: slideUp 0.28s ease;
    line-height: 0;
  }

  .closing .popup-box {
    animation: slideDown 0.25s ease forwards;
  }

  .popup-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .popup-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: #fff;
    font-size: 1.3rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    z-index: 2;
    transition: background 0.2s ease;
  }

  .popup-close:hover { background: rgba(0, 0, 0, 0.75); }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes fadeOut {
    from { opacity: 1; }
    to   { opacity: 0; }
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  @keyframes slideDown {
    from { transform: translateY(0);    opacity: 1; }
    to   { transform: translateY(16px); opacity: 0; }
  }
</style>
