---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto – Bolívar Plaza"
  description="Contáctanos. Centro Comercial Bolívar Plaza, Cra 8 N 19-41, Pereira, Risaralda. Teléfono, correo y formulario de contacto."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contáct<span>anos</span></h1>
      <p>Estamos aquí para ayudarte</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">

      <!-- Info Column -->
      <div class="contact-info">

        <div class="info-card">
          <h2>Horario de atención</h2>
          <table class="hours-table">
            <tbody>
              <tr>
                <th scope="row">Lunes – Viernes</th>
                <td>9:00 am – 7:00 pm</td>
              </tr>
              <tr>
                <th scope="row">Sábado</th>
                <td>9:00 am – 7:00 pm</td>
              </tr>
              <tr>
                <th scope="row">Domingos y festivos</th>
                <td>11:00 am – 4:00 pm</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="info-card">
          <h2>Información de contacto</h2>
          <ul class="contact-list">
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>Cra 8 N 19-41, Pereira<br />Risaralda, Colombia</span>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.55a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <a href="tel:+576XXXXXXXX">(606) 000-0000</a>
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a href="mailto:info@bolivarplaza.com">info@bolivarplaza.com</a>
            </li>
          </ul>
        </div>

        <!-- Map -->
        <div class="map-wrapper">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3976.5!2d-75.6972!3d4.8143!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e38867e6c1d3f5b%3A0x0!2sCra+8+%2319-41%2C+Pereira%2C+Risaralda!5e0!3m2!1ses!2sco!4v1700000000000"
            width="100%"
            height="260"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Bolívar Plaza en Google Maps"
          ></iframe>
        </div>
      </div>

      <!-- Form Column -->
      <div class="contact-form-wrap">
        <div class="info-card form-card">
          <h2>Envíanos un mensaje</h2>
          <form
            class="contact-form"
            name="contacto"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/gracias"
          >
            <input type="hidden" name="form-name" value="contacto" />
            <p hidden><label>No llenar: <input name="bot-field" /></label></p>

            <div class="form-group">
              <label for="nombre">Nombre completo</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                autocomplete="name"
              />
            </div>

            <div class="form-group">
              <label for="email">Correo electrónico</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tu@correo.com"
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label for="mensaje">Mensaje</label>
              <textarea
                id="mensaje"
                name="mensaje"
                required
                rows="5"
                placeholder="¿En qué podemos ayudarte?"
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary submit-btn">
              Enviar mensaje
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>
          </form>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--navy);
    color: var(--white);
    padding: 3rem 0 2.5rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .page-header h1 span { color: var(--green); }

  .page-header p {
    color: rgba(255,255,255,0.72);
    font-size: 1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-grid { grid-template-columns: 1fr 1fr; }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.5rem 1.75rem;
  }

  .info-card h2 {
    font-size: 1.05rem;
    color: var(--navy);
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--gray-light);
  }

  /* Hours table */
  .hours-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .hours-table th {
    text-align: left;
    font-weight: 600;
    color: var(--text-muted);
    padding: 0.5rem 0;
    padding-right: 1rem;
    white-space: nowrap;
    width: 55%;
  }

  .hours-table td {
    font-weight: 700;
    color: var(--navy);
    padding: 0.5rem 0;
  }

  .hours-table tr + tr th,
  .hours-table tr + tr td {
    border-top: 1px solid var(--gray-light);
  }

  /* Contact list */
  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text);
  }

  .contact-list svg {
    flex-shrink: 0;
    color: var(--green);
    margin-top: 1px;
  }

  .contact-list a {
    color: var(--navy);
    font-weight: 600;
    transition: color var(--transition);
  }

  .contact-list a:hover { color: var(--green); }

  /* Map */
  .map-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    line-height: 0;
  }

  /* Form */
  .form-card { padding: 1.75rem 2rem; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-top: 0.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--navy);
  }

  .form-group input,
  .form-group textarea {
    padding: 0.65rem 0.9rem;
    border: 2px solid var(--gray-mid);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    transition: border-color var(--transition);
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--navy);
  }

  .submit-btn {
    align-self: flex-start;
    gap: 0.5rem;
  }
</style>
