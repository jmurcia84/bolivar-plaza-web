---
import Layout from '../layouts/Layout.astro';
import StoreCard from '../components/StoreCard.astro';

const stores = [
  { name: "McDonald's", category: 'Comidas', floor: 'Piso 1', description: 'Hamburguesas, papas y más' },
  { name: 'Cruz Verde', category: 'Servicios', floor: 'Piso 1', description: 'Farmacia y droguería' },
  { name: 'Royal Films', category: 'Entretenimiento', floor: 'Piso 2', description: 'Cine multiplex' },
  { name: 'Play Point', category: 'Entretenimiento', floor: 'Piso 2', description: 'Zona de juegos y diversión' },
  { name: 'Stop Jeans', category: 'Moda', floor: 'Piso 1', description: 'Ropa casual y denim' },
  { name: 'Ristretto', category: 'Comidas', floor: 'Piso 1', description: 'Café y bebidas especiales' },
  { name: 'Qbano', category: 'Comidas', floor: 'Piso 1', description: 'Sándwiches y comida rápida colombiana' },
  { name: 'Essence', category: 'Moda', floor: 'Piso 2', description: 'Perfumería y cosméticos' },
];

const categories = ['Todos', 'Moda', 'Comidas', 'Entretenimiento', 'Servicios'];
---

<Layout
  title="Directorio de Tiendas – Bolívar Plaza"
  description="Explora todas las tiendas de Centro Comercial Bolívar Plaza en Pereira. Moda, comidas, entretenimiento y servicios."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Directorio de <span>Tiendas</span></h1>
      <p>Encuentra todas las tiendas, restaurantes y servicios de Bolívar Plaza</p>
    </div>
  </section>

  <!-- Search & Filter -->
  <section class="section section-gray">
    <div class="container">
      <div class="search-bar">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          id="store-search"
          placeholder="Buscar tienda…"
          aria-label="Buscar tienda"
          autocomplete="off"
        />
      </div>

      <div class="filter-buttons" role="group" aria-label="Filtrar por categoría">
        {categories.map((cat) => (
          <button
            class={`filter-btn ${cat === 'Todos' ? 'active' : ''}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Stores Grid -->
  <section class="section">
    <div class="container">
      <p class="results-count" id="results-count" aria-live="polite"></p>
      <div class="grid-cards" id="stores-grid">
        {stores.map((store) => (
          <div class="store-wrapper" data-name={store.name.toLowerCase()} data-category={store.category}>
            <StoreCard {...store} />
          </div>
        ))}
      </div>
      <p class="no-results" id="no-results" hidden>
        No se encontraron tiendas con esos criterios.
      </p>
    </div>
  </section>
</Layout>

<script>
  const searchInput = document.getElementById('store-search') as HTMLInputElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const wrappers = document.querySelectorAll<HTMLElement>('.store-wrapper');
  const noResults = document.getElementById('no-results');
  const countEl = document.getElementById('results-count');

  let activeCategory = 'Todos';
  let searchTerm = '';

  function updateVisibility() {
    let visible = 0;
    wrappers.forEach((w) => {
      const name = w.dataset.name ?? '';
      const cat = w.dataset.category ?? '';
      const matchesSearch = name.includes(searchTerm);
      const matchesCat = activeCategory === 'Todos' || cat === activeCategory;
      const show = matchesSearch && matchesCat;
      w.hidden = !show;
      if (show) visible++;
    });

    if (noResults) noResults.hidden = visible > 0;
    if (countEl) {
      countEl.textContent = visible === wrappers.length
        ? ''
        : `${visible} tienda${visible !== 1 ? 's' : ''} encontrada${visible !== 1 ? 's' : ''}`;
    }
  }

  searchInput?.addEventListener('input', () => {
    searchTerm = searchInput.value.toLowerCase().trim();
    updateVisibility();
  });

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.category ?? 'Todos';
      updateVisibility();
    });
  });
</script>

<style>
  .page-header {
    background: var(--navy);
    color: var(--white);
    padding: 3rem 0 2.5rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .page-header h1 span { color: var(--gold); }

  .page-header p {
    color: rgba(255,255,255,0.72);
    font-size: 1rem;
  }

  .search-bar {
    position: relative;
    max-width: 480px;
    margin-bottom: 1.25rem;
  }

  .search-icon {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  #store-search {
    width: 100%;
    padding: 0.7rem 1rem 0.7rem 2.6rem;
    border: 2px solid var(--gray-mid);
    border-radius: var(--radius);
    font-size: 0.95rem;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    transition: border-color var(--transition);
  }

  #store-search:focus {
    outline: none;
    border-color: var(--navy);
  }

  .filter-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.45rem 1.1rem;
    border-radius: 20px;
    border: 2px solid var(--gray-mid);
    background: var(--white);
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--transition);
  }

  .filter-btn:hover {
    border-color: var(--navy);
    color: var(--navy);
  }

  .filter-btn.active {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--white);
  }

  .results-count {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    min-height: 1.4em;
  }

  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding: 2rem 0;
    font-size: 1rem;
  }

  .store-wrapper[hidden] { display: none; }
</style>
