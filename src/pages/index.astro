---
import Layout from '../layouts/Layout.astro';
import StoreCard from '../components/StoreCard.astro';
import Popup from '../components/Popup.astro';

const featuredStores = [
  { name: "McDonald's", category: 'Comidas', floor: 'Piso 1', description: 'Hamburguesas, papas y más' },
  { name: 'Cruz Verde', category: 'Servicios', floor: 'Piso 1', description: 'Farmacia y droguería' },
  { name: 'Royal Films', category: 'Entretenimiento', floor: 'Piso 2', description: 'Cine multiplex' },
  { name: 'Stop Jeans', category: 'Moda', floor: 'Piso 1', description: 'Ropa casual y denim' },
  { name: 'Ristretto', category: 'Comidas', floor: 'Piso 1', description: 'Café y bebidas especiales' },
  { name: 'Essence', category: 'Moda', floor: 'Piso 2', description: 'Perfumería y cosméticos' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ShoppingCenter',
  name: 'Centro Comercial Bolívar Plaza',
  description: 'Centro comercial en Pereira, Risaralda con tiendas de moda, restaurantes, entretenimiento y servicios.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Cra 8 N 19-41',
    addressLocality: 'Pereira',
    addressRegion: 'Risaralda',
    addressCountry: 'CO',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
      opens: '09:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Sunday'],
      opens: '11:00',
      closes: '16:00',
    },
  ],
};
---

<Layout
  title="Bolívar Plaza – Centro Comercial en Pereira, Risaralda"
  description="Visita Centro Comercial Bolívar Plaza en Pereira. Más de 50 tiendas, restaurantes, cine y entretenimiento. Cra 8 N 19-41."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- Hero Slider -->
  <section class="hero" id="hero-slider" aria-label="Carrusel de bienvenida" aria-roledescription="carousel">
    <div class="slides-track" id="slides-track">

      <div class="slide slide-1 active" role="group" aria-roledescription="slide" aria-label="Diapositiva 1 de 3">
        <div class="slide-overlay"></div>
        <div class="container slide-content">
          <p class="hero-eyebrow">Bienvenido a</p>
          <h1 class="hero-title">Bolívar <span>Plaza</span></h1>
          <p class="hero-sub">Tu destino favorito en Pereira. Moda, comida, entretenimiento y más, todo en un solo lugar.</p>
          <div class="hero-actions">
            <a href="/directorio" class="btn btn-primary">Ver tiendas</a>
            <a href="/eventos" class="btn btn-outline-white">Eventos</a>
          </div>
        </div>
      </div>

      <div class="slide slide-2" role="group" aria-roledescription="slide" aria-label="Diapositiva 2 de 3">
        <div class="slide-overlay"></div>
        <div class="container slide-content">
          <p class="hero-eyebrow">Zona de comidas</p>
          <h2 class="hero-title">Sabores para <span>todos</span></h2>
          <p class="hero-sub">McDonald's, Ristretto, Qbano y más. Una experiencia gastronómica completa bajo un mismo techo.</p>
          <div class="hero-actions">
            <a href="/directorio?cat=Comidas" class="btn btn-primary">Ver restaurantes</a>
          </div>
        </div>
      </div>

      <div class="slide slide-3" role="group" aria-roledescription="slide" aria-label="Diapositiva 3 de 3">
        <div class="slide-overlay"></div>
        <div class="container slide-content">
          <p class="hero-eyebrow">Entretenimiento</p>
          <h2 class="hero-title">Diversión sin <span>límites</span></h2>
          <p class="hero-sub">Royal Films y Play Point te esperan. Planes increíbles para toda la familia en Pereira.</p>
          <div class="hero-actions">
            <a href="/eventos" class="btn btn-primary">Ver eventos</a>
            <a href="/directorio" class="btn btn-outline-white">Directorio</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Prev / Next -->
    <button class="slider-btn slider-prev" id="slider-prev" aria-label="Diapositiva anterior">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="slider-btn slider-next" id="slider-next" aria-label="Siguiente diapositiva">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

    <!-- Dots -->
    <div class="slider-dots" role="tablist" aria-label="Seleccionar diapositiva">
      <button class="dot active" role="tab" aria-selected="true" aria-label="Ir a diapositiva 1" data-index="0"></button>
      <button class="dot" role="tab" aria-selected="false" aria-label="Ir a diapositiva 2" data-index="1"></button>
      <button class="dot" role="tab" aria-selected="false" aria-label="Ir a diapositiva 3" data-index="2"></button>
    </div>
  </section>

  <script>
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');
    const prevBtn = document.getElementById('slider-prev');
    const nextBtn = document.getElementById('slider-next');
    let current = 0;
    let timer;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      dots[current].setAttribute('aria-selected', 'false');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
      dots[current].setAttribute('aria-selected', 'true');
    }

    function startAuto() {
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    prevBtn?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => { goTo(Number(dot.dataset.index)); resetAuto(); });
    });

    // Swipe support
    let touchStartX = 0;
    const hero = document.getElementById('hero-slider');
    hero?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    hero?.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) { goTo(dx < 0 ? current + 1 : current - 1); resetAuto(); }
    });

    // Pause on hover
    hero?.addEventListener('mouseenter', () => clearInterval(timer));
    hero?.addEventListener('mouseleave', startAuto);

    startAuto();
  </script>

  <!-- Hours -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">Horario de <span>atención</span></h2>
      <div class="hours-grid">
        <div class="hours-card">
          <div class="hours-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="hours-label">Lunes – Sábado</p>
            <p class="hours-time">9:00 am – 7:00 pm</p>
          </div>
        </div>
        <div class="hours-card">
          <div class="hours-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="hours-label">Domingos y festivos</p>
            <p class="hours-time">11:00 am – 4:00 pm</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Stores -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Nuestras <span>Tiendas</span></h2>
      <div class="grid-cards">
        {featuredStores.map((store) => (
          <StoreCard {...store} />
        ))}
      </div>
      <div class="stores-cta">
        <a href="/directorio" class="btn btn-outline">Ver directorio completo</a>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">¿Por qué visitarnos?</h2>
      <div class="features-grid">
        <div class="feature">
          <div class="feature-icon">🛍️</div>
          <h3>+50 tiendas</h3>
          <p>Moda, tecnología, hogar, servicios y mucho más reunidos en un solo lugar.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🍔</div>
          <h3>Zona de comidas</h3>
          <p>Disfruta de una amplia variedad gastronómica para todos los gustos.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🎬</div>
          <h3>Entretenimiento</h3>
          <p>Cine, zona de juegos y eventos especiales para toda la familia.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🅿️</div>
          <h3>Parqueadero</h3>
          <p>Amplio estacionamiento con fácil acceso para tu comodidad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popup -->
  <Popup
    title="¡Ofertas de temporada!"
    body="Descubre las mejores promociones de nuestras tiendas. Esta semana, descuentos especiales en moda y restaurantes."
    buttonLabel="Ver promociones"
    buttonUrl="/directorio"
    active={true}
  />
</Layout>

<style>
  /* ── Hero Slider ── */
  .hero {
    position: relative;
    min-height: 560px;
    overflow: hidden;
    user-select: none;
  }

  .slides-track {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: inherit;
  }

  /* Individual slides */
  .slide {
    position: absolute;
    inset: 0;
    min-height: 560px;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 0.75s ease;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    position: relative;
    pointer-events: auto;
  }

  /* Slide backgrounds */
  .slide-1 {
    background: linear-gradient(135deg, #0f2447 0%, #1A3C6E 55%, #1e4d8c 100%);
  }

  .slide-1::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .slide-2 {
    background: linear-gradient(135deg, #3d1a00 0%, #7b3800 55%, #a35000 100%);
  }

  .slide-3 {
    background: linear-gradient(135deg, #0a2a1a 0%, #1a5c3a 55%, #1e7045 100%);
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.55) 0%, transparent 70%);
  }

  .slide-content {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 5rem;
    max-width: 640px;
  }

  .hero-eyebrow {
    color: var(--gold);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--white);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .hero-title span { color: var(--gold); }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.82);
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-actions { display: flex; gap: 0.85rem; flex-wrap: wrap; }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.6rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.95rem;
    border: 2px solid rgba(255,255,255,0.55);
    color: var(--white);
    background: transparent;
    transition: border-color var(--transition), background var(--transition);
  }

  .btn-outline-white:hover {
    border-color: var(--white);
    background: rgba(255,255,255,0.1);
  }

  /* Prev / Next buttons */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 2px solid rgba(255,255,255,0.25);
    color: var(--white);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition);
    backdrop-filter: blur(4px);
  }

  .slider-btn:hover {
    background: rgba(232,160,32,0.85);
    border-color: var(--gold);
    color: var(--navy);
  }

  .slider-prev { left: 1.1rem; }
  .slider-next { right: 1.1rem; }

  @media (min-width: 768px) {
    .slider-prev { left: 2rem; }
    .slider-next { right: 2rem; }
  }

  /* Dots */
  .slider-dots {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), border-color var(--transition), transform var(--transition);
  }

  .dot.active {
    background: var(--gold);
    border-color: var(--gold);
    transform: scale(1.25);
  }

  /* Hours */
  .hours-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 680px;
    margin: 0 auto;
  }

  @media (min-width: 540px) {
    .hours-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .hours-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--gold);
  }

  .hours-icon { color: var(--navy); flex-shrink: 0; }

  .hours-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }

  .hours-time {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
  }

  /* Stores CTA */
  .stores-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* Features */
  .features-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 768px) {
    .features-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .feature {
    text-align: center;
    padding: 1.75rem 1rem;
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .feature-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
  }

  .feature h3 {
    font-size: 1rem;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .feature p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
</style>
