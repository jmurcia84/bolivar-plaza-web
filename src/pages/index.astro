---
import Layout from '../layouts/Layout.astro';
import StoreCard from '../components/StoreCard.astro';
import Popup from '../components/Popup.astro';

const storeModules = import.meta.glob('../content/stores/*.md', { eager: true });
const featuredStores = Object.values(storeModules)
  .map((m) => m.frontmatter)
  .slice(0, 6);

const bannerModules = import.meta.glob('../content/banners/*.md', { eager: true });
const banners = Object.values(bannerModules)
  .map((m) => m.frontmatter)
  .filter((b) => b.active !== false && b.image)
  .sort((a, b) => {
    // sort by filename via the module key
    const keys = Object.keys(bannerModules);
    return keys.findIndex(k => bannerModules[k].frontmatter === a) -
           keys.findIndex(k => bannerModules[k].frontmatter === b);
  });

const popup = await import('../content/popup.json');
const settings = await import('../content/settings.json');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ShoppingCenter',
  name: 'Centro Comercial Bolívar Plaza',
  description: 'Centro comercial en Pereira, Risaralda con tiendas de moda, restaurantes, entretenimiento y servicios.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Cra 8 N 19-41',
    addressLocality: 'Pereira',
    addressRegion: 'Risaralda',
    addressCountry: 'CO',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
      opens: '09:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Sunday'],
      opens: '11:00',
      closes: '16:00',
    },
  ],
};
---

<Layout
  title="Bolívar Plaza – Centro Comercial en Pereira, Risaralda"
  description="Visita Centro Comercial Bolívar Plaza en Pereira. Más de 50 tiendas, restaurantes, cine y entretenimiento. Cra 8 N 19-41."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- Hero Slider -->
  <section class="hero" id="hero-slider" aria-label="Carrusel de bienvenida" aria-roledescription="carousel">
    <div class="slides-track" id="slides-track">

      {banners.map((banner, i) => (
        <div
          class:list={['slide', { active: i === 0 }]}
          role="group"
          aria-roledescription="slide"
          aria-label={`Diapositiva ${i + 1} de ${banners.length}`}
        >
          {banner.link_url ? (
            <a href={banner.link_url} class="slide-inner">
              <img
                src={banner.image}
                alt={banner.title || `Banner ${i + 1} – Bolívar Plaza`}
                class="slide-bg-img"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </a>
          ) : (
            <div class="slide-inner">
              <img
                src={banner.image}
                alt={banner.title || `Banner ${i + 1} – Bolívar Plaza`}
                class="slide-bg-img"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          )}
        </div>
      ))}

    </div>

    <!-- Prev / Next -->
    <button class="slider-btn slider-prev" id="slider-prev" aria-label="Diapositiva anterior">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="slider-btn slider-next" id="slider-next" aria-label="Siguiente diapositiva">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

    <!-- Dots -->
    <div class="slider-dots" role="tablist" aria-label="Seleccionar diapositiva">
      {banners.map((_, i) => (
        <button
          class:list={['dot', { active: i === 0 }]}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Ir a diapositiva ${i + 1}`}
          data-index={i}
        ></button>
      ))}
    </div>
  </section>

  <script>
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');
    const prevBtn = document.getElementById('slider-prev');
    const nextBtn = document.getElementById('slider-next');
    let current = 0;
    let timer;

    function goTo(index) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      dots[current].setAttribute('aria-selected', 'false');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
      dots[current].setAttribute('aria-selected', 'true');
    }

    function startAuto() {
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    prevBtn?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => { goTo(Number(dot.dataset.index)); resetAuto(); });
    });

    // Swipe support
    let touchStartX = 0;
    const hero = document.getElementById('hero-slider');
    hero?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    hero?.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) { goTo(dx < 0 ? current + 1 : current - 1); resetAuto(); }
    });

    // Pause on hover
    hero?.addEventListener('mouseenter', () => clearInterval(timer));
    hero?.addEventListener('mouseleave', startAuto);

    startAuto();
  </script>

  <!-- Hours -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">Horario de <span>atención</span></h2>
      <div class="hours-grid">
        <div class="hours-card">
          <div class="hours-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="hours-label">Lunes – Sábado</p>
            <p class="hours-time">9:00 am – 7:00 pm</p>
          </div>
        </div>
        <div class="hours-card">
          <div class="hours-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="hours-label">Domingos y festivos</p>
            <p class="hours-time">11:00 am – 4:00 pm</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Stores -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Nuestras <span>Tiendas</span></h2>
      <div class="grid-cards">
        {featuredStores.map((store) => (
          <StoreCard {...store} />
        ))}
      </div>
      <div class="stores-cta">
        <a href="/directorio" class="btn btn-outline">Ver directorio completo</a>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">¿Por qué visitarnos?</h2>
      <div class="features-grid">
        <div class="feature">
          <div class="feature-icon">🛍️</div>
          <h3>+50 tiendas</h3>
          <p>Moda, tecnología, hogar, servicios y mucho más reunidos en un solo lugar.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🍔</div>
          <h3>Zona de comidas</h3>
          <p>Disfruta de una amplia variedad gastronómica para todos los gustos.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🎬</div>
          <h3>Entretenimiento</h3>
          <p>Cine, zona de juegos y eventos especiales para toda la familia.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🅿️</div>
          <h3>Parqueadero</h3>
          <p>Amplio estacionamiento con fácil acceso para tu comodidad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popup -->
  <Popup
    image={popup.image}
    active={popup.active}
  />
</Layout>

<style>
  /* ── Hero Slider ── */
  .hero {
    position: relative;
    /* Fixed height: 56vw on mobile, capped at 600px on desktop */
    height: clamp(280px, 56vw, 600px);
    overflow: hidden;
    user-select: none;
  }

  .slides-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Individual slides */
  .slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 0.75s ease;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    position: absolute;
    pointer-events: auto;
  }

  /* Slide image fill */
  .slide-inner {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #000;
  }

  .slide-bg-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .slide-content {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 5rem;
    max-width: 640px;
  }

  .hero-eyebrow {
    color: #d6f0ab;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    color: var(--white);
    line-height: 1.05;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .hero-title span { color: #d6f0ab; }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.88);
    line-height: 1.65;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  .hero-actions { display: flex; gap: 0.85rem; flex-wrap: wrap; }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.6rem;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 2px solid rgba(255,255,255,0.6);
    color: var(--white);
    background: transparent;
    transition: border-color var(--transition), background var(--transition);
  }

  .btn-outline-white:hover {
    border-color: var(--white);
    background: rgba(255,255,255,0.1);
  }

  /* Prev / Next buttons */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.12);
    border: 2px solid rgba(255,255,255,0.25);
    color: var(--white);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition);
    backdrop-filter: blur(4px);
  }

  .slider-btn:hover {
    background: rgba(232,160,32,0.85);
    border-color: var(--green);
    color: var(--navy);
  }

  .slider-prev { left: 1.1rem; }
  .slider-next { right: 1.1rem; }

  @media (min-width: 768px) {
    .slider-prev { left: 2rem; }
    .slider-next { right: 2rem; }
  }

  /* Dots */
  .slider-dots {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background var(--transition), border-color var(--transition), transform var(--transition);
  }

  .dot.active {
    background: var(--green);
    border-color: var(--green);
    transform: scale(1.25);
  }

  /* Hours */
  .hours-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 680px;
    margin: 0 auto;
  }

  @media (min-width: 540px) {
    .hours-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .hours-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    box-shadow: var(--shadow);
    border-left: 4px solid var(--green);
  }

  .hours-icon { color: var(--green); flex-shrink: 0; }

  .hours-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }

  .hours-time {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
  }

  /* Stores CTA */
  .stores-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* Features */
  .features-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 768px) {
    .features-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .feature {
    text-align: center;
    padding: 1.75rem 1rem;
    background: var(--white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .feature-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
  }

  .feature h3 {
    font-size: 1rem;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .feature p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
</style>
