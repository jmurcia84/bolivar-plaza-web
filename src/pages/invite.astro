---
// Standalone identity page – no layout, no popup, nothing else
// Handles: invite_token, recovery_token, confirmation_token
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex" />
  <title>Acceso – Bolívar Plaza</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #f0f0f0;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.10);
      padding: 2.5rem 2rem;
      text-align: center;
      max-width: 360px;
      width: 90%;
    }
    img { height: 48px; width: auto; margin-bottom: 1rem; }
    h1 { font-size: 1.05rem; color: #222; margin-bottom: 0.5rem; }
    p { color: #666; font-size: 0.875rem; line-height: 1.5; }
    #status-msg { margin-top: 1rem; font-size: 0.8rem; color: #999; }
    #status-msg.error { color: #c0392b; }
  </style>
</head>
<body>
  <div class="card">
    <img src="/uploads/logo-bolivar-plaza.png" alt="Bolívar Plaza" />
    <h1>Acceso al panel de administración</h1>
    <p>Verificando tu enlace… el formulario aparecerá en un momento.</p>
    <p id="status-msg"></p>
  </div>

  <!-- is:inline prevents Astro from hoisting/bundling these scripts -->
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script is:inline>
    var statusEl = document.getElementById('status-msg');

    function initIdentity() {
      if (!window.netlifyIdentity) {
        statusEl.textContent = 'No se pudo cargar el widget. Recarga la página.';
        statusEl.className = 'error';
        return;
      }

      window.netlifyIdentity.on('init', function(user) {
        if (user) {
          window.location.href = '/admin/';
        }
        // Widget will automatically show the set-password form
        // when invite_token or recovery_token is in the URL hash.
        // Do NOT call open() — it overrides the token handling.
      });

      window.netlifyIdentity.on('login', function() {
        window.location.href = '/admin/';
      });

      window.netlifyIdentity.on('error', function(err) {
        statusEl.textContent = 'Error: ' + (err && err.message ? err.message : 'El enlace puede haber expirado. Solicita uno nuevo desde Netlify.');
        statusEl.className = 'error';
      });
    }

    // Run after full page load to ensure widget script has executed
    if (document.readyState === 'complete') {
      initIdentity();
    } else {
      window.addEventListener('load', initIdentity);
    }
  </script>
</body>
</html>
