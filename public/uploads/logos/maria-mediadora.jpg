<script>                  
 $(document).ready(function(){
  $('.restau li > a').click(function() {
	   var id =  $(this).attr('data-dato');
	  	
		jQuery.get("consulta_desc_subcategorias.php", {id:id }, function(resultado){
			if(resultado == false){
				$('.desc_comida').html("<h2 class='color_white'>No se encontro</h2>");
				
				
			}else{

				$('.desc_comida').html(resultado);
			}
		}); 
  });
 });
</script>
<script>                  
 $(document).ready(function(){
  $('.restau2 li > a').click(function() {
	   var id =  $(this).attr('data-dato');
	  	
		jQuery.get("consulta_desc_subcategoriast.php", {id:id }, function(resultado){
			if(resultado == false){
				$('.res_tiendas').html("<h2 class='color_white'>No se encontro</h2>");
				
				
			}else{

				$('.res_tiendas').html(resultado);
			}
		}); 
  });
 });
</script>


 
